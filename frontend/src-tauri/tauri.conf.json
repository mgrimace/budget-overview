{
  "productName": "Budget Overview",
  "version": "0.1.0",
  "identifier": "com.budget.overview",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "",
    "devUrl": "http://127.0.0.1:3001",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Budget Overview",
        "url": "http://127.0.0.1:3001",
        "width": 1280,
        "height": 800,
        "visible": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../dist/**/*": "www/"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
